{
  "name": "seller-autopilot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:integration": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "npm@10.8.0"
}
