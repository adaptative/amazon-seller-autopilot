# ═══════════════════════════════════════════════════════════════
# Amazon Seller Autopilot — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git — it's in .gitignore.
# See Issue #108 for step-by-step setup instructions.
# ═══════════════════════════════════════════════════════════════

# ── SP-API Credentials ──────────────────────────────────────
SP_API_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXX
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.XXXXXXXXX
SP_API_REFRESH_TOKEN=Atzr|XXXXXXXXXX
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER
SP_API_SELLER_ID=AXXXXXXXXXX
SP_API_SANDBOX=true
SP_API_ENDPOINT=https://sandbox.sellingpartnerapi-na.amazon.com

# ── AWS Credentials (for SP-API signing) ────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/sp-api-role
AWS_REGION=us-east-1

# ── Amazon Ads API Credentials ──────────────────────────────
ADS_API_CLIENT_ID=amzn1.application-oa2-client.YYYYYYYYY
ADS_API_CLIENT_SECRET=amzn1.oa2-cs.v1.YYYYYYYYY
ADS_API_REFRESH_TOKEN=Atzr|YYYYYYYYYY
ADS_API_PROFILE_ID=1234567890
ADS_API_SANDBOX=true
ADS_API_ENDPOINT=https://advertising-api-test.amazon.com

# ── Amazon Ads MCP Server ───────────────────────────────────
ADS_MCP_ENABLED=true
ADS_MCP_ENDPOINT=https://mcp.advertising.amazon.com/mcp

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://autopilot:autopilot@localhost:5432/autopilot_dev
DATABASE_TEST_URL=postgresql://test:test@localhost:5433/autopilot_test
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXX

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-strong-random-key
JWT_EXPIRY_MINUTES=60

# ── Stripe (Billing — use test keys) ───────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXX

# ── LocalStack (Local AWS mock for dev) ─────────────────────
LOCALSTACK_ENDPOINT=http://localhost:4566
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/sp-api-notifications
